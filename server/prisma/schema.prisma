generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enumerations ──────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

/// Pricing tier — set by the Stripe webhook handler on subscription create/update.
/// Defaults to FREE for new schools until a Stripe subscription is confirmed.
enum SubscriptionPlan {
  FREE
  TIER_1
  TIER_2
}

enum AuditAction {
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  SCHOOL_CREATED
  SCHOOL_UPDATED
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_UPDATED
  SUBSCRIPTION_CANCELED
  LOGIN
  LOGOUT
}

/// Privacy level for telemetry events (matches event-dictionary.md L0–L3 scale).
enum TelemetryLevel {
  L0 // Anonymous counts — no identifier
  L1 // School-scoped counts — school_id only
  L2 // User-scoped — anonymised user_id
  L3 // With structured metadata (never PII)
}

// ── Models ────────────────────────────────────────────────────────────────────

model School {
  id        String    @id @default(cuid())
  name      String
  domain    String?   @unique
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // soft-delete; hard-deleted after 90 days by retention-sweep

  users         User[]
  subscriptions Subscription[]
  auditLogs     AuditLog[]

  @@map("schools")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  displayName  String    @map("display_name")
  role         UserRole  @default(TEACHER)
  passwordHash String?   @map("password_hash")
  schoolId     String    @map("school_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at") // soft-delete; hard-deleted after 90 days by retention-sweep

  school    School     @relation(fields: [schoolId], references: [id])
  auditLogs AuditLog[]

  @@index([schoolId])
  @@map("users")
}

model Subscription {
  id                   String             @id @default(cuid())
  schoolId             String             @map("school_id")
  stripeCustomerId     String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  stripePriceId        String?            @map("stripe_price_id")
  plan                 SubscriptionPlan   @default(FREE) @map("plan")
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@map("subscriptions")
}

model AuditLog {
  id        String      @id @default(cuid())
  schoolId  String      @map("school_id")
  userId    String?     @map("user_id")
  action    AuditAction
  metadata  Json?
  ipAddress String?     @map("ip_address")
  userAgent String?     @map("user_agent")
  createdAt DateTime    @default(now()) @map("created_at")

  school School  @relation(fields: [schoolId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  @@index([schoolId, createdAt])
  @@index([userId])
  @@map("audit_logs")
}

/// Feature flag definition. Evaluation logic lives in server/src/lib/flags.ts.
/// Admin Console reads/writes this table; the API exposes evaluated values via GET /api/flags.
/// No FK to School — flags are global config, not per-school rows.
model FeatureFlag {
  /// Kebab-case identifier, e.g. "relief-workflow-v2". Immutable after creation.
  key             String           @id
  description     String           // human-readable purpose, shown in Admin Console
  /// Return value when there is no school context (anonymous callers) or when no other rule matches.
  defaultEnabled  Boolean          @default(false) @map("default_enabled")
  /// True = this flag is a kill switch for a risky feature. Ships with defaultEnabled=false.
  killSwitch      Boolean          @default(false) @map("kill_switch")
  /// 0–100. 0 = nobody (unless allowlisted). 100 = everybody (unless denylisted).
  rolloutPct      Int              @default(0) @map("rollout_pct")
  /// School IDs that always get the flag ON regardless of rolloutPct.
  allowlist       String[]         @default([]) @map("allowlist")
  /// School IDs that always get the flag OFF regardless of rolloutPct or allowlist.
  denylist        String[]         @default([]) @map("denylist")
  /// If set, schools on a lower plan see defaultEnabled (flag is invisible to them).
  requiredPlan    SubscriptionPlan? @map("required_plan")
  /// Optional hygiene deadline — flags at 100%/0% past this date appear in the stale report.
  expiresAt       DateTime?        @map("expires_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@map("feature_flags")
}

/// Product-analytics events. Separate from AuditLog — different retention, different access controls.
/// Populated by server/src/lib/telemetry/emit.ts. Never contains L4+ data (PII / scraped content).
/// Access: read-only for product analytics role; write-only for the API/worker.
model TelemetryEvent {
  id         String         @id @default(cuid())
  event      String         // event name, matches event-dictionary.md
  level      TelemetryLevel
  schoolId   String?        @map("school_id")  // null for L0 events
  userId     String?        @map("user_id")    // anonymised ID only; null unless L2
  props      Json           // structured metadata, never PII
  createdAt  DateTime       @default(now()) @map("created_at")

  @@index([event, createdAt])
  @@index([schoolId, createdAt])
  @@map("telemetry_events")
}
