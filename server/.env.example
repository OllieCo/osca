# Dispatcher server — environment variable template
# Copy to .env and fill in values. Never commit .env to git.
#
# DISPATCHER_ENV controls the visible environment banner and data-isolation gates.
# NODE_ENV controls library behaviour (Express error detail, etc.)

# ─── Runtime identity ────────────────────────────────────────────────────────
NODE_ENV=development
# Options: development | staging | production
DISPATCHER_ENV=dev
# Options: dev | staging | prod

# ─── Network ─────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:3000
# staging: https://staging.dispatcher.app
# prod:    https://dispatcher.app

# ─── Inference ───────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:12b

# ─── Persistence ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://dispatcher:dispatcher@localhost:5432/dispatcher_dev
# prod: use a connection pooler URL (e.g. PgBouncer / Supabase pooler)
REDIS_URL=redis://localhost:6379

# ─── Auth (required once Auth Unification lands) ─────────────────────────────
# JWT_SECRET=<min 32 chars — generate: openssl rand -hex 32>

# ─── Payments (required once Stripe integration lands) ───────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email (required once Resend integration lands) ──────────────────────────
# RESEND_API_KEY=re_...

# ─── Observability ───────────────────────────────────────────────────────────
# Omit GRAFANA_OTLP_ENDPOINT to disable OTel in dev (no telemetry sent)
# GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-au-southeast-1.grafana.net/otlp
# GRAFANA_OTLP_TOKEN=<Grafana Cloud OTLP token — Connections → OpenTelemetry → Direct → Generate token>
# Omit SENTRY_DSN to disable Sentry
# SENTRY_DSN=https://...@o0.ingest.au.sentry.io/...
