# Copy this file to server/.env and fill in values for local development.
# All variables listed here must be documented — CI validates completeness.

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
DISPATCHER_ENV=dev          # dev | staging | prod
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://dispatcher:dispatcher@localhost:5432/dispatcher_dev

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Inference ────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Observability (optional — leave blank to disable) ────────────────────────
GRAFANA_OTLP_ENDPOINT=
GRAFANA_OTLP_TOKEN=
SENTRY_DSN=
